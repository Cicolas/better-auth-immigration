{
  "name": "better-auth-immigration",
  "version": "0.1.1",
  "description": "Better Auth plugin for exchanging legacy auth credentials for Better Auth sessions.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "better-auth",
    "auth",
    "migration",
    "legacy-auth"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "better-auth": ">=1.5.0 <2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "better-auth": "~1.5.6",
    "typescript": "^5.9.3"
  }
}
